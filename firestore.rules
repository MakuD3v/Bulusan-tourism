rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Secure user profiles: only the user can modify their own data
    match /users/{userId} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default rule for all other collections (Attractions, Accommodations, Blogs, etc.)
    // Anyone can read (so the public site works).
    // Only authenticated users (Admins) can write.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
