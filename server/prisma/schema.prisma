generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String           @id @default(uuid())
  name        String
  email       String           @unique
  password    String
  role        String           @default("USER")
  avatar      String?
  itinerary   Int[]
  history     String[]
  joinedDate  DateTime         @default(now())
  checkIns    CheckIn[]
  customTours CustomUserTour[]
}

model Attraction {
  id              Int      @id @default(autoincrement())
  name            String
  categories      String[]
  rating          Float    @default(0)
  location        String
  lat             Float
  lng             Float
  img             String
  description     String
  gallery         String[]
  droneVideoId    String?
  videoUrl        String?
  metadata        Json?
  contactInfo     String?
  visits          Int      @default(0)
  dateAdded       DateTime @default(now())
  tags            String[]
  featured        Boolean  @default(false)
  photos          String[]
  isFreeAdmission Boolean  @default(false)
  offers          Offer[]
  reviews         Review[]
}

model Enterprise {
  id          Int      @id @default(autoincrement())
  name        String
  categories  String[]
  rating      Float    @default(0)
  location    String
  lat         Float
  lng         Float
  img         String
  description String
  rates       String?
  amenities   String[]
  gallery     String[]
  videoUrl    String?
  metadata    Json?
  visits      Int      @default(0)
  dateAdded   DateTime @default(now())
  tags        String[]
  featured    Boolean  @default(false)
  photos      String[]
  offers      Offer[]
  reviews     Review[]
}

model Heritage {
  id           Int      @id @default(autoincrement())
  name         String
  period       String
  location     String
  description  String
  fullHistory  String
  significance String
  img          String
  gallery      String[]
  videoUrl     String?
  lat          Float
  lng          Float
  visits       Int      @default(0)
  rating       Float    @default(0)
  tags         String[]
  photos       String[]
  reviews      Review[]
}

model Offer {
  id           String      @id @default(uuid())
  name         String
  price        String
  image        String?
  attractionId Int?
  enterpriseId Int?
  attraction   Attraction? @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  enterprise   Enterprise? @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
}

model Review {
  id           Int         @id @default(autoincrement())
  author       String
  avatar       String
  rating       Float
  comment      String
  date         DateTime    @default(now())
  attractionId Int?
  enterpriseId Int?
  heritageId   Int?
  attraction   Attraction? @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  enterprise   Enterprise? @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  heritage     Heritage?   @relation(fields: [heritageId], references: [id], onDelete: Cascade)
}

model Tour {
  id         Int      @id @default(autoincrement())
  title      String
  desc       String
  image      String
  duration   String
  groupSize  String
  price      String
  highlights String[]
  visits     Int      @default(0)
  rating     Float    @default(0)
  dateAdded  DateTime @default(now())
  tags       String[]
  routes     Route[]
}

model Route {
  id          Int     @id @default(autoincrement())
  time        String
  location    String
  desc        String
  type        String?
  referenceId Int?
  autoTime    Int?
  tourId      Int
  tour        Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id           Int      @id @default(autoincrement())
  title        String
  category     String
  excerpt      String
  content      String
  authorName   String
  authorAvatar String
  date         DateTime @default(now())
  image        String
  readTime     String
  status       String   @default("Published")
}

model Inquiry {
  id      Int      @id @default(autoincrement())
  sender  String
  email   String
  subject String
  message String
  date    DateTime @default(now())
  status  String   @default("New")
}

model CheckIn {
  id           Int      @id @default(autoincrement())
  userId       String
  userName     String
  locationId   String
  locationName String
  timestamp    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CustomUserTour {
  id           String                @id @default(uuid())
  userId       String
  name         String
  createdAt    DateTime              @default(now())
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  destinations UserTourDestination[]
}

model UserTourDestination {
  id           String         @id @default(uuid())
  itemId       String
  entityType   String
  completed    Boolean        @default(false)
  customTourId String
  customTour   CustomUserTour @relation(fields: [customTourId], references: [id], onDelete: Cascade)
}

model GlobalStat {
  id            Int @id @default(1)
  totalVisitors Int @default(0)
}
